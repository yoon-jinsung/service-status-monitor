{
  "pollingIntervalMinutes": 5,
  "defaultAlertChannel": "#ce-service-status-monitor",
  "services": [
    {
      "name": "GitHub",
      "type": "statuspage",
      "baseUrl": "https://www.githubstatus.com",
      "enabled": true,
      "mentionOnCritical": "@here"
    },
    {
      "name": "Notion",
      "type": "statuspage",
      "baseUrl": "https://www.notion-status.com",
      "enabled": true,
      "mentionOnCritical": "@here"
    },
    {
      "name": "API Gateway (Seoul)",
      "type": "aws_rss",
      "baseUrl": "https://health.aws.amazon.com/health/status",
      "statusUrl": "https://status.aws.amazon.com/rss/apigateway-ap-northeast-2.rss",
      "enabled": true,
      "mentionOnCritical": "@here"
    },
    {
      "name": "API Gateway (Tokyo)",
      "type": "aws_rss",
      "baseUrl": "https://health.aws.amazon.com/health/status",
      "statusUrl": "https://status.aws.amazon.com/rss/apigateway-ap-northeast-1.rss",
      "enabled": true,
      "mentionOnCritical": "@here"
    },
    {
      "name": "Slack",
      "type": "custom_slack",
      "baseUrl": "https://slack-status.com",
      "statusUrl": "https://slack-status.com/api/v2.0.0/current",
      "enabled": true,
      "mentionOnCritical": "@here"
    }
  ]
}
